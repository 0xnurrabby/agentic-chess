# --- Coinbase Developer Platform (CDP) v2 ---
# Get these at https://portal.cdp.coinbase.com → API Keys → Create
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# REQUIRED for v2 to sign transactions.
# Get from https://portal.cdp.coinbase.com → Wallets → Wallet Secret
# Without this, the app falls back to mock mode automatically.
CDP_WALLET_SECRET=

# --- Paymaster (ERC-7677) ---
# Optional — CDP smart accounts on Base auto-use the managed paymaster.
# Set this only if you want to point at a specific paymaster RPC.
PAYMASTER_URL=

# --- Smart Contract ---
# Deploy contracts/AgenticChess.sol via Remix, paste address here.
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# --- Base Builder Code ---
# Get from https://base.dev → Settings → Builder Code
BASE_BUILDER_CODE=

# --- Network ---
# 'base-sepolia' (84532) for dev, 'base' (8453) for prod mainnet
NEXT_PUBLIC_CHAIN=base

# --- Concurrent games ---
# How many games run simultaneously. 1-12 recommended.
NUM_GAMES=5

# --- Per-move pacing (random delay between each move) ---
MIN_MOVE_DELAY_MS=3000
MAX_MOVE_DELAY_MS=5000

# --- Wallet / agent pool (1:1 — each agent has its own CDP smart account) ---
# MAX_WALLETS: hard cap on total agents seeded. Wallets are lazily provisioned
# on first play, so unused agents cost ZERO CDP operations.
MAX_WALLETS=500

# At startup the platform picks a random integer K in [MIN_ACTIVE_AGENTS,
# MAX_ACTIVE_AGENTS]. Those first K agents are the active rotation pool —
# they take turns playing across the NUM_GAMES concurrent boards. Agents
# beyond K stay dormant until you raise the range and restart.
MIN_ACTIVE_AGENTS=300
MAX_ACTIVE_AGENTS=400

# --- At-rest encryption (optional) ---
# 64 hex chars = 32 bytes. When set, data/agents.json is AES-256-GCM encrypted.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# --- Cron Auth ---
# Random string to protect /api/agent-engine cron endpoint in production.
CRON_SECRET=

# --- Mock mode ---
# 'auto' (default): real if CDP_WALLET_SECRET is set, mock otherwise.
# 'true' / 'false' to force either way.
MOCK_BLOCKCHAIN=auto
